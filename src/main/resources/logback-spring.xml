<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ─── Console appender ─────────────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ─── Axiom appender ────────────────────────────────────────────── -->
    <appender name="AXIOM" class="io.github.yhsj.axiom.AxiomAppender">
        <endpointUrl>https://api.axiom.co/v1/datasets/${AXIOM_DATASET:-socialapp-logs}/ingest</endpointUrl>
        <apiToken>${AXIOM_TOKEN}</apiToken>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>

    <!-- ─── Local / dev profile: Console only ────────────────────────── -->
    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ─── Prod profile: Axiom only ─────────────────────────────────── -->
    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="AXIOM"/>
        </root>
        <logger name="com.socialapp" level="INFO" additivity="false">
            <appender-ref ref="AXIOM"/>
        </logger>
    </springProfile>

</configuration>
